  "alert_severity_thresholds": {
    "CRITICAL": {
      "breach_magnitude": 2.0,
      "confidence_min": 85,
      "description": "Limit breached by more than 2 percentage points OR multiple limit violations",
      "escalation_required": true
    },
    "HIGH": {
      "breach_magnitude": 1.0,
      "confidence_min": 80,
      "description": "Limit breached by 1-2 percentage points",
      "escalation_required": true
    },
    "MEDIUM": {
      "breach_magnitude": 0.5,
      "confidence_min": 70,
      "description": "Approaching limit (80-100% of limit) OR single-digit breach",
      "escalation_required": false
    },
    "LOW": {
      "breach_magnitude": 0.0,
      "confidence_min": 60,
      "description": "Minor exposure issues or correlation warnings",
      "escalation_required": false
    }
  },
  "escalation_rules": {
    "CRITICAL": {
      "slack_channel": "#portfolio-risk-critical",
      "jira_priority": "Blocker",
      "notify_cfo": true,
      "notify_risk_head": true,
      "estimated_action_time_minutes": 5,
      "actions": [
        "Create CRITICAL Jira ticket",
        "Send Slack alert to #portfolio-risk-critical",
        "Notify CFO and Chief Risk Officer via email",
        "Update dashboard with real-time flag"
      ]
    },
    "HIGH": {
      "slack_channel": "#portfolio-risk-alerts",
      "jira_priority": "High",
      "notify_cfo": false,
      "notify_risk_head": true,
      "estimated_action_time_minutes": 15,
      "actions": [
        "Create High-priority Jira ticket",
        "Send Slack alert to #portfolio-risk-alerts",
        "Notify Chief Risk Officer",
        "Update dashboard with breach flag"
      ]
    },
    "MEDIUM": {
      "slack_channel": "#portfolio-monitoring",
      "jira_priority": "Medium",
      "notify_cfo": false,
      "notify_risk_head": false,
      "estimated_action_time_minutes": 30,
      "actions": [
        "Log in risk monitoring system",
        "Send Slack notification to #portfolio-monitoring",
        "Update dashboard"
      ]
    },
    "LOW": {
      "slack_channel": "#portfolio-monitoring",
      "jira_priority": "Low",
      "notify_cfo": false,
      "notify_risk_head": false,
      "estimated_action_time_minutes": 60,
      "actions": [
        "Log in risk monitoring system",
        "Update dashboard"
      ]
    }
  }
}
